{
  "name": "@caysonverse/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/index.cjs --tsconfig=tsconfig.json",
    "start": "node dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.27",
    "colyseus": "^0.17.10",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.17.11",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
