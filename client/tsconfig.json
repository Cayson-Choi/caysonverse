{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,

    // `connection.ts` does `import type { WorldState }` from the shared schema
    // (type-only — the decorator runtime never enters the browser bundle). The
    // shared alias resolves to SOURCE, so tsc still typechecks schema.ts, which
    // relies on @colyseus/schema legacy decorators. These two flags must match
    // shared/server tsconfig for that file to typecheck; the client has no
    // decorators or class fields of its own, so its emitted output is unaffected.
    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "baseUrl": ".",
    "paths": {
      "@caysonverse/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
